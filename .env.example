# Copy to .env and fill in. .env is git-ignored — secrets never get committed.
# All values are optional for the local profile; defaults are shown.

# ── Server deployment (docker-compose.server.yml) ────────────────────────────
#HARBOR_REGISTRY=harbor.your-company.com
#APP_HOST=cortex.your-company.com
#KEYCLOAK_HOST=auth.your-company.com
#OIDC_PUBLIC_ORIGIN=https://cortex.your-company.com
#TRAEFIK_NETWORK=traefik
#TRAEFIK_CERT_RESOLVER=                # leave empty if Traefik uses static certs

# ── Branding ──────────────────────────────────────────────────────────────────
# Name shown in the header and browser tab.
#APP_NAME=Cortex

# ── Keycloak ──────────────────────────────────────────────────────────────────
KEYCLOAK_ADMIN_PASSWORD=admin

# ── OIDC ──────────────────────────────────────────────────────────────────────
# Client secret of the cortex-app client in the cortex realm.
OIDC_CLIENT_SECRET=cortex-secret

# Production only: HTTPS Keycloak realm URL (RequireHttpsMetadata=true in prod),
# and the browser-facing Keycloak origin if it differs from the authority.
#OIDC_AUTHORITY=https://keycloak.example.com/realms/cortex
#OIDC_PUBLIC_ORIGIN=https://keycloak.example.com

# ── Azure DevOps connector (leave empty to ingest the local ./docs folder) ────
#ADO_BASE_URL=https://ado.example.com/DefaultCollection
#ADO_PROJECT=MyProject
#ADO_REPOSITORY=internal-docs
#ADO_PATH=/
#ADO_BRANCH=main
#ADO_PAT=
#ADO_WEBHOOK_SECRET=

# ── GitHub connector (leave empty to skip) ────────────────────────────────────
#GITHUB_OWNER=my-org
#GITHUB_REPOSITORY=internal-docs
#GITHUB_PATH=/
#GITHUB_BRANCH=main
#GITHUB_PAT=
#GITHUB_WEBHOOK_SECRET=

# ── Codespaces (written automatically by start-codespaces.sh) ─────────────────
#KEYCLOAK_PUBLIC_URL=
